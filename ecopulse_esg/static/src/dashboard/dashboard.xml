<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="ecopulse_esg.EcoPulseDashboard">

        <div class="o_ecopulse_dashboard">

            <!-- Dashboard Header -->
            <section class="eco_dashboard_header">

                <div>
                    <div class="eco_eyebrow">
                        ENVIRONMENTAL INTELLIGENCE PLATFORM
                    </div>

                    <h1>EcoPulse ESG Command Center</h1>

                    <p>
                        Monitor carbon emissions, environmental goals,
                        departments, risks and sustainability performance
                        from one centralized dashboard.
                    </p>
                </div>

                <div class="eco_header_actions">

                    <div class="eco_last_updated">
                        <i class="fa fa-clock-o"/>
                        Last updated:
                        <strong>
                            <t t-esc="state.lastUpdated || '—'"/>
                        </strong>
                    </div>

                    <button
                        type="button"
                        class="btn eco_refresh_button"
                        t-on-click="refreshDashboard">

                        <i class="fa fa-refresh me-2"/>
                        Refresh

                    </button>

                </div>

            </section>


            <!-- Loading State -->
            <t t-if="state.loading">

                <div class="eco_loading_panel">

                    <div class="eco_loader"/>

                    <h3>Preparing sustainability intelligence</h3>

                    <p>
                        Loading live carbon, goal and department analytics...
                    </p>

                </div>

            </t>


            <!-- Main Dashboard -->
            <t t-else="">

                <!-- Primary KPI Cards -->
                <section class="eco_kpi_grid">

                    <article
                        class="eco_kpi_card eco_kpi_primary"
                        role="button"
                        t-on-click="openCarbonTransactions">

                        <div class="eco_kpi_top">

                            <div class="eco_icon_box">
                                <i class="fa fa-leaf"/>
                            </div>

                            <span class="eco_card_link">
                                View details
                                <i class="fa fa-arrow-right"/>
                            </span>

                        </div>

                        <div class="eco_kpi_label">
                            Total Carbon Emissions
                        </div>

                        <div class="eco_kpi_value">
                            <t t-esc="formatNumber(state.totalEmissions)"/>
                        </div>

                        <div class="eco_kpi_unit">
                            kg CO₂e recorded
                        </div>

                    </article>


                    <article
                        class="eco_kpi_card"
                        role="button"
                        t-on-click="openCarbonTransactions">

                        <div class="eco_kpi_top">

                            <div class="eco_icon_box eco_icon_blue">
                                <i class="fa fa-exchange"/>
                            </div>

                            <span class="eco_card_link">
                                Open
                                <i class="fa fa-arrow-right"/>
                            </span>

                        </div>

                        <div class="eco_kpi_label">
                            Carbon Transactions
                        </div>

                        <div class="eco_kpi_value">
                            <t t-esc="state.carbonTransactions"/>
                        </div>

                        <div class="eco_kpi_unit">
                            emission activity records
                        </div>

                    </article>


                    <article
                        class="eco_kpi_card"
                        role="button"
                        t-on-click="openEnvironmentalGoals">

                        <div class="eco_kpi_top">

                            <div class="eco_icon_box eco_icon_orange">
                                <i class="fa fa-bullseye"/>
                            </div>

                            <span class="eco_card_link">
                                Open
                                <i class="fa fa-arrow-right"/>
                            </span>

                        </div>

                        <div class="eco_kpi_label">
                            Environmental Goals
                        </div>

                        <div class="eco_kpi_value">
                            <t t-esc="state.environmentalGoals"/>
                        </div>

                        <div class="eco_kpi_unit">
                            sustainability targets
                        </div>

                    </article>


                    <article
                        class="eco_kpi_card"
                        role="button"
                        t-on-click="openDepartments">

                        <div class="eco_kpi_top">

                            <div class="eco_icon_box eco_icon_purple">
                                <i class="fa fa-building"/>
                            </div>

                            <span class="eco_card_link">
                                Open
                                <i class="fa fa-arrow-right"/>
                            </span>

                        </div>

                        <div class="eco_kpi_label">
                            Departments
                        </div>

                        <div class="eco_kpi_value">
                            <t t-esc="state.departments"/>
                        </div>

                        <div class="eco_kpi_unit">
                            monitored business units
                        </div>

                    </article>

                </section>


                <!-- Transaction Status Cards -->
                <section class="eco_status_summary_grid">

                    <div class="eco_status_summary_card">

                        <div class="eco_status_summary_icon eco_verified_icon">
                            <i class="fa fa-check-circle"/>
                        </div>

                        <div>
                            <span>Verified Transactions</span>

                            <strong>
                                <t t-esc="state.verifiedTransactions"/>
                            </strong>
                        </div>

                    </div>


                    <div class="eco_status_summary_card">

                        <div class="eco_status_summary_icon eco_calculated_icon">
                            <i class="fa fa-calculator"/>
                        </div>

                        <div>
                            <span>Calculated Transactions</span>

                            <strong>
                                <t t-esc="state.calculatedTransactions"/>
                            </strong>
                        </div>

                    </div>


                    <div class="eco_status_summary_card">

                        <div class="eco_status_summary_icon eco_draft_icon">
                            <i class="fa fa-pencil-square-o"/>
                        </div>

                        <div>
                            <span>Draft Transactions</span>

                            <strong>
                                <t t-esc="state.draftTransactions"/>
                            </strong>
                        </div>

                    </div>


                    <div class="eco_status_summary_card">

                        <div class="eco_status_summary_icon eco_factor_icon">
                            <i class="fa fa-sliders"/>
                        </div>

                        <div>
                            <span>Emission Factors</span>

                            <strong>
                                <t t-esc="state.emissionFactors"/>
                            </strong>
                        </div>

                    </div>

                </section>


                <!-- Monthly Analytics -->
                <section class="eco_analytics_grid">

                    <article class="eco_panel eco_monthly_panel">

                        <div class="eco_panel_header">

                            <div>
                                <h2>Monthly Emission Trend</h2>

                                <p>
                                    Carbon emissions recorded during the
                                    latest twelve active months.
                                </p>
                            </div>

                            <div class="eco_panel_icon">
                                <i class="fa fa-bar-chart"/>
                            </div>

                        </div>


                        <t t-if="state.monthlyEmissions.length">

                            <div class="eco_chart_summary">

                                <div>
                                    <span>Highest Emission Month</span>

                                    <strong>
                                        <t t-esc="state.highestEmissionMonth"/>
                                    </strong>
                                </div>

                                <div>
                                    <span>Emission Recorded</span>

                                    <strong>
                                        <t t-esc="formatNumber(state.highestEmissionMonthValue)"/>
                                        kg CO₂e
                                    </strong>
                                </div>

                            </div>


                            <div class="eco_monthly_chart">

                                <t
                                    t-foreach="state.monthlyEmissions"
                                    t-as="month"
                                    t-key="month.key">

                                    <div class="eco_month_column">

                                        <div class="eco_month_value">
                                            <t t-esc="formatNumber(month.total)"/>
                                        </div>

                                        <div class="eco_month_bar_area">

                                            <div
                                                class="eco_month_bar"
                                                t-att-style="'height: ' + getMonthlyBarHeight(month.total) + '%'">

                                                <span class="eco_month_bar_tooltip">
                                                    <t t-esc="month.label"/>
                                                    :
                                                    <t t-esc="formatNumber(month.total)"/>
                                                    kg CO₂e
                                                </span>

                                            </div>

                                        </div>

                                        <div class="eco_month_label">
                                            <t t-esc="month.shortLabel"/>
                                        </div>

                                    </div>

                                </t>

                            </div>

                        </t>


                        <t t-else="">

                            <div class="eco_empty_state">

                                <div class="eco_empty_icon">
                                    <i class="fa fa-bar-chart"/>
                                </div>

                                <h3>No monthly emission data</h3>

                                <p>
                                    Add carbon transactions to generate
                                    monthly emission analytics.
                                </p>

                                <button
                                    type="button"
                                    class="btn eco_refresh_button"
                                    t-on-click="createCarbonTransaction">

                                    Add Carbon Transaction

                                </button>

                            </div>

                        </t>

                    </article>


                    <!-- Department Leaderboard -->
                    <article class="eco_panel">

                        <div class="eco_panel_header">

                            <div>
                                <h2>Department Emission Leaderboard</h2>

                                <p>
                                    Departments ranked by total carbon
                                    emissions.
                                </p>
                            </div>

                            <div class="eco_panel_icon">
                                <i class="fa fa-trophy"/>
                            </div>

                        </div>


                        <div class="eco_top_department_card">

                            <div class="eco_top_department_icon">
                                <i class="fa fa-building"/>
                            </div>

                            <div>
                                <span>Highest Emitting Department</span>

                                <strong>
                                    <t t-esc="state.topDepartment"/>
                                </strong>

                                <small>
                                    <t t-esc="formatNumber(state.topDepartmentEmission)"/>
                                    kg CO₂e
                                </small>
                            </div>

                        </div>


                        <t t-if="state.departmentRanking.length">

                            <div class="eco_department_ranking">

                                <t
                                    t-foreach="state.departmentRanking"
                                    t-as="department"
                                    t-key="department.id">

                                    <div class="eco_department_item">

                                        <div class="eco_department_rank">
                                            <t t-esc="department.rank"/>
                                        </div>

                                        <div class="eco_department_details">

                                            <div class="eco_department_heading">

                                                <div>
                                                    <strong>
                                                        <t t-esc="department.name"/>
                                                    </strong>

                                                    <span>
                                                        <t t-esc="department.transactions"/>
                                                        transactions
                                                    </span>
                                                </div>

                                                <strong>
                                                    <t t-esc="formatNumber(department.total)"/>
                                                </strong>

                                            </div>

                                            <div class="eco_department_track">

                                                <div
                                                    class="eco_department_fill"
                                                    t-att-style="'width: ' + getDepartmentBarWidth(department.total) + '%'"/>

                                            </div>

                                        </div>

                                    </div>

                                </t>

                            </div>

                        </t>


                        <t t-else="">

                            <div class="eco_small_empty_state">
                                No department emission information available.
                            </div>

                        </t>

                    </article>

                </section>


                <!-- Scope and Source Analytics -->
                <section class="eco_content_grid">

                    <!-- Scope Distribution -->
                    <article class="eco_panel">

                        <div class="eco_panel_header">

                            <div>
                                <h2>Emission Scope Distribution</h2>

                                <p>
                                    Carbon emissions divided across
                                    operational scopes.
                                </p>
                            </div>

                            <div class="eco_panel_icon">
                                <i class="fa fa-pie-chart"/>
                            </div>

                        </div>


                        <div class="eco_scope_item">

                            <div class="eco_scope_heading">

                                <div>
                                    <span class="eco_scope_dot eco_scope_1"/>
                                    <strong>Scope 1</strong>
                                    <span>Direct emissions</span>
                                </div>

                                <strong>
                                    <t t-esc="state.scope1Percent"/>%
                                </strong>

                            </div>

                            <div class="eco_progress_track">

                                <div
                                    class="eco_progress_fill eco_fill_1"
                                    t-att-style="'width: ' + state.scope1Percent + '%'"/>

                            </div>

                            <small>
                                <t t-esc="formatNumber(state.scope1Total)"/>
                                kg CO₂e
                            </small>

                        </div>


                        <div class="eco_scope_item">

                            <div class="eco_scope_heading">

                                <div>
                                    <span class="eco_scope_dot eco_scope_2"/>
                                    <strong>Scope 2</strong>
                                    <span>Purchased energy</span>
                                </div>

                                <strong>
                                    <t t-esc="state.scope2Percent"/>%
                                </strong>

                            </div>

                            <div class="eco_progress_track">

                                <div
                                    class="eco_progress_fill eco_fill_2"
                                    t-att-style="'width: ' + state.scope2Percent + '%'"/>

                            </div>

                            <small>
                                <t t-esc="formatNumber(state.scope2Total)"/>
                                kg CO₂e
                            </small>

                        </div>


                        <div class="eco_scope_item">

                            <div class="eco_scope_heading">

                                <div>
                                    <span class="eco_scope_dot eco_scope_3"/>
                                    <strong>Scope 3</strong>
                                    <span>Value-chain emissions</span>
                                </div>

                                <strong>
                                    <t t-esc="state.scope3Percent"/>%
                                </strong>

                            </div>

                            <div class="eco_progress_track">

                                <div
                                    class="eco_progress_fill eco_fill_3"
                                    t-att-style="'width: ' + state.scope3Percent + '%'"/>

                            </div>

                            <small>
                                <t t-esc="formatNumber(state.scope3Total)"/>
                                kg CO₂e
                            </small>

                        </div>

                    </article>


                    <!-- Source Analytics -->
                    <article class="eco_panel">

                        <div class="eco_panel_header">

                            <div>
                                <h2>Emission Sources</h2>

                                <p>
                                    Carbon contribution grouped by source
                                    module.
                                </p>
                            </div>

                            <div class="eco_panel_icon">
                                <i class="fa fa-sitemap"/>
                            </div>

                        </div>


                        <div class="eco_top_source_card">

                            <span>Top Emission Source</span>

                            <strong>
                                <t t-esc="state.topSource"/>
                            </strong>

                            <small>
                                <t t-esc="formatNumber(state.topSourceEmission)"/>
                                kg CO₂e
                            </small>

                        </div>


                        <t t-if="state.sourceAnalytics.length">

                            <div class="eco_source_grid">

                                <t
                                    t-foreach="state.sourceAnalytics"
                                    t-as="source"
                                    t-key="source.key">

                                    <div class="eco_source_card">

                                        <div class="eco_source_icon">

                                            <i
                                                t-att-class="'fa ' + getSourceIcon(source.key)"/>

                                        </div>

                                        <div class="eco_source_details">

                                            <strong>
                                                <t t-esc="source.label"/>
                                            </strong>

                                            <span>
                                                <t t-esc="source.transactions"/>
                                                transactions
                                            </span>

                                        </div>

                                        <div class="eco_source_total">

                                            <strong>
                                                <t t-esc="formatNumber(source.total)"/>
                                            </strong>

                                            <span>kg CO₂e</span>

                                        </div>

                                    </div>

                                </t>

                            </div>

                        </t>


                        <t t-else="">

                            <div class="eco_small_empty_state">
                                No source analytics available.
                            </div>

                        </t>

                    </article>

                </section>


                <!-- Goal Analytics and Alerts -->
                <section class="eco_goal_analytics">

                    <article class="eco_panel">

                        <div class="eco_panel_header">

                            <div>
                                <h2>Environmental Goal Performance</h2>

                                <p>
                                    Real-time progress and risk monitoring
                                    for sustainability targets.
                                </p>
                            </div>

                            <button
                                type="button"
                                class="btn eco_text_button"
                                t-on-click="openEnvironmentalGoals">

                                View all goals
                                <i class="fa fa-arrow-right ms-2"/>

                            </button>

                        </div>


                        <div class="eco_goal_summary_grid">

                            <div class="eco_goal_summary">

                                <span>Average Progress</span>

                                <strong>
                                    <t t-esc="state.averageGoalProgress"/>%
                                </strong>

                            </div>


                            <div class="eco_goal_summary">

                                <span>Active Goals</span>

                                <strong>
                                    <t t-esc="state.activeGoals"/>
                                </strong>

                            </div>


                            <div class="eco_goal_summary eco_goal_summary_success">

                                <span>Completed</span>

                                <strong>
                                    <t t-esc="state.completedGoals"/>
                                </strong>

                            </div>


                            <div class="eco_goal_summary eco_goal_summary_risk">

                                <span>At Risk</span>

                                <strong>
                                    <t t-esc="state.atRiskGoals"/>
                                </strong>

                            </div>

                        </div>


                        <t t-if="state.goalRecords.length">

                            <div class="eco_goal_list">

                                <t
                                    t-foreach="state.goalRecords"
                                    t-as="goal"
                                    t-key="goal.id">

                                    <div class="eco_goal_item">

                                        <div class="eco_goal_info">

                                            <div class="eco_goal_title_row">

                                                <strong>
                                                    <t t-esc="goal.name"/>
                                                </strong>

                                                <span
                                                    t-att-class="'eco_goal_status ' + getGoalStatusClass(goal.status)">

                                                    <t t-esc="getGoalStatusLabel(goal.status)"/>

                                                </span>

                                            </div>


                                            <div class="eco_goal_meta">

                                                <span>
                                                    <i class="fa fa-building-o me-1"/>
                                                    <t t-esc="getDepartmentName(goal.department_id)"/>
                                                </span>

                                                <span>
                                                    <i class="fa fa-calendar me-1"/>
                                                    <t t-esc="goal.end_date || 'No deadline'"/>
                                                </span>

                                                <span>
                                                    <i class="fa fa-line-chart me-1"/>
                                                    <t t-esc="getMetricLabel(goal.metric_type)"/>
                                                </span>

                                            </div>


                                            <div class="eco_goal_progress_track">

                                                <div
                                                    class="eco_goal_progress_fill"
                                                    t-att-style="'width: ' + goal.progress_percentage + '%'"/>

                                            </div>

                                        </div>


                                        <div class="eco_goal_percentage">

                                            <strong>
                                                <t t-esc="formatNumber(goal.progress_percentage)"/>%
                                            </strong>

                                            <span>completed</span>

                                        </div>

                                    </div>

                                </t>

                            </div>

                        </t>


                        <t t-else="">

                            <div class="eco_empty_state">

                                <div class="eco_empty_icon">
                                    <i class="fa fa-bullseye"/>
                                </div>

                                <h3>No environmental goals yet</h3>

                                <p>
                                    Create a sustainability target to begin
                                    goal-performance analysis.
                                </p>

                                <button
                                    type="button"
                                    class="btn eco_refresh_button"
                                    t-on-click="createEnvironmentalGoal">

                                    Create First Goal

                                </button>

                            </div>

                        </t>

                    </article>


                    <!-- Alerts -->
                    <article class="eco_panel">

                        <div class="eco_panel_header">

                            <div>
                                <h2>Sustainability Alerts</h2>

                                <p>
                                    Goals requiring review or immediate action.
                                </p>
                            </div>

                            <div class="eco_panel_icon">
                                <i class="fa fa-bell"/>
                            </div>

                        </div>


                        <t t-if="state.alerts.length">

                            <div class="eco_alert_list">

                                <t
                                    t-foreach="state.alerts"
                                    t-as="alert"
                                    t-key="alert.id">

                                    <div
                                        t-att-class="'eco_alert_item ' + getRiskClass(alert.level)">

                                        <div class="eco_alert_icon">
                                            <i class="fa fa-exclamation-triangle"/>
                                        </div>

                                        <div>

                                            <strong>
                                                <t t-esc="alert.title"/>
                                            </strong>

                                            <p>
                                                <t t-esc="alert.message"/>
                                            </p>

                                        </div>

                                    </div>

                                </t>

                            </div>

                        </t>


                        <t t-else="">

                            <div class="eco_no_alerts">

                                <i class="fa fa-check-circle"/>

                                <h3>All goals are on track</h3>

                                <p>
                                    No critical sustainability alerts were
                                    detected.
                                </p>

                            </div>

                        </t>

                    </article>

                </section>


                <!-- Recent Carbon Transactions -->
                <section class="eco_panel eco_recent_panel">

                    <div class="eco_panel_header">

                        <div>
                            <h2>Recent Carbon Transactions</h2>

                            <p>
                                Latest emission activities recorded in
                                EcoPulse ESG.
                            </p>
                        </div>

                        <button
                            type="button"
                            class="btn eco_text_button"
                            t-on-click="openCarbonTransactions">

                            View all transactions
                            <i class="fa fa-arrow-right ms-2"/>

                        </button>

                    </div>


                    <t t-if="state.recentTransactions.length">

                        <div class="table-responsive">

                            <table class="table eco_transaction_table">

                                <thead>

                                    <tr>
                                        <th>Reference</th>
                                        <th>Date</th>
                                        <th>Department</th>
                                        <th>Source</th>
                                        <th>Scope</th>
                                        <th>Emission</th>
                                        <th>Status</th>
                                    </tr>

                                </thead>

                                <tbody>

                                    <t
                                        t-foreach="state.recentTransactions"
                                        t-as="transaction"
                                        t-key="transaction.id">

                                        <tr>

                                            <td>
                                                <strong>
                                                    <t t-esc="transaction.reference || 'New'"/>
                                                </strong>
                                            </td>

                                            <td>
                                                <t t-esc="transaction.transaction_date || '—'"/>
                                            </td>

                                            <td>
                                                <t t-esc="getDepartmentName(transaction.department_id)"/>
                                            </td>

                                            <td>

                                                <span class="eco_source_badge">

                                                    <i
                                                        t-att-class="'fa ' + getSourceIcon(transaction.source_module) + ' me-1'"/>

                                                    <t t-esc="getSourceLabel(transaction.source_module)"/>

                                                </span>

                                            </td>

                                            <td>
                                                <span class="eco_scope_badge">
                                                    <t t-esc="getScopeLabel(transaction.scope)"/>
                                                </span>
                                            </td>

                                            <td>

                                                <strong>
                                                    <t t-esc="formatNumber(transaction.calculated_emission)"/>
                                                </strong>

                                                <small> kg CO₂e</small>

                                            </td>

                                            <td>

                                                <span
                                                    t-att-class="'eco_status_badge ' + getStatusClass(transaction.status)">

                                                    <t t-esc="getStatusLabel(transaction.status)"/>

                                                </span>

                                            </td>

                                        </tr>

                                    </t>

                                </tbody>

                            </table>

                        </div>

                    </t>


                    <t t-else="">

                        <div class="eco_empty_state">

                            <div class="eco_empty_icon">
                                <i class="fa fa-leaf"/>
                            </div>

                            <h3>No carbon transactions yet</h3>

                            <p>
                                Add the first transaction to begin
                                carbon-emission analysis.
                            </p>

                            <button
                                type="button"
                                class="btn eco_refresh_button"
                                t-on-click="createCarbonTransaction">

                                Add First Transaction

                            </button>

                        </div>

                    </t>

                </section>


                <!-- Quick Actions -->
                <section class="eco_panel eco_quick_action_panel">

                    <div class="eco_panel_header">

                        <div>
                            <h2>Quick Actions</h2>

                            <p>
                                Create and manage sustainability records
                                directly from the dashboard.
                            </p>
                        </div>

                        <div class="eco_panel_icon">
                            <i class="fa fa-bolt"/>
                        </div>

                    </div>


                    <div class="eco_quick_actions eco_quick_actions_horizontal">

                        <button
                            type="button"
                            class="eco_action_button eco_action_primary"
                            t-on-click="createCarbonTransaction">

                            <span class="eco_action_icon">
                                <i class="fa fa-plus"/>
                            </span>

                            <span>
                                <strong>Record Carbon Activity</strong>

                                <small>
                                    Add a new emission transaction
                                </small>
                            </span>

