<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- EcoPulse application category -->
    <record id="module_category_ecopulse_esg" model="ir.module.category">
        <field name="name">EcoPulse ESG</field>
        <field name="description">
            Environmental, Social and Governance Management
        </field>
        <field name="sequence">30</field>
    </record>

    <!-- Odoo 19 privilege -->
    <record id="privilege_ecopulse_esg" model="res.groups.privilege">
        <field name="name">EcoPulse ESG</field>
        <field name="category_id" ref="module_category_ecopulse_esg"/>
        <field name="sequence">30</field>
    </record>

    <!-- Employee group -->
    <record id="group_ecopulse_employee" model="res.groups">
        <field name="name">ESG Employee</field>
        <field name="privilege_id" ref="privilege_ecopulse_esg"/>
        <field name="sequence">10</field>
        <field name="implied_ids"
               eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager group -->
    <record id="group_ecopulse_manager" model="res.groups">
        <field name="name">ESG Manager</field>
        <field name="privilege_id" ref="privilege_ecopulse_esg"/>
        <field name="sequence">20</field>
        <field name="implied_ids"
               eval="[(4, ref('group_ecopulse_employee'))]"/>
    </record>

    <!-- Administrator group -->
    <record id="group_ecopulse_admin" model="res.groups">
        <field name="name">ESG Administrator</field>
        <field name="privilege_id" ref="privilege_ecopulse_esg"/>
        <field name="sequence">30</field>
        <field name="implied_ids"
               eval="[(4, ref('group_ecopulse_manager'))]"/>
    </record>

</odoo>