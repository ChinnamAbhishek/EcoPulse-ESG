<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record
        id="view_ecopulse_esg_report_wizard_form"
        model="ir.ui.view">

        <field name="name">
            ecopulse.esg.report.wizard.form
        </field>

        <field name="model">
            ecopulse.esg.report.wizard
        </field>

        <field name="arch" type="xml">

            <form string="Generate ESG Report">

                <sheet>

                    <div class="oe_title">
                        <h1>Professional ESG Report</h1>

                        <p>
                            Select the reporting period and filters to
                            generate a detailed sustainability PDF report.
                        </p>
                    </div>

                    <group>

                        <group string="Reporting Period">

                            <field name="start_date"/>

                            <field name="end_date"/>

                        </group>

                        <group string="Transaction Filters">

                            <field name="department_id"/>

                            <field name="scope"/>

                            <field name="transaction_status"/>

                        </group>

                    </group>

                    <group string="Report Options">

                        <field name="include_cancelled"/>

                        <field name="include_goals"/>

                        <field name="include_department_analysis"/>

                        <field name="include_source_analysis"/>

                    </group>

                    <div class="alert alert-info" role="alert">

                        The report will include carbon-emission totals,
                        scope distribution, transaction status,
                        monthly analysis and selected ESG insights.

                    </div>

                </sheet>

                <footer>

                    <button
                        name="action_print_report"
                        type="object"
                        string="Generate PDF"
                        class="btn-primary"
                        icon="fa-file-pdf-o"/>

                    <button
                        string="Cancel"
                        special="cancel"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>


    <record
        id="action_ecopulse_esg_report_wizard"
        model="ir.actions.act_window">

        <field name="name">
            Generate ESG Report
        </field>

        <field name="res_model">
            ecopulse.esg.report.wizard
        </field>

        <field name="view_mode">
            form
        </field>

        <field name="view_id"
               ref="view_ecopulse_esg_report_wizard_form"/>

        <field name="target">
            new
        </field>

    </record>

</odoo>