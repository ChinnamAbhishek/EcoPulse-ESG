<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- Main EcoPulse App Menu -->
    <menuitem
        id="menu_ecopulse_root"
        name="EcoPulse ESG"
        sequence="10"
    />

    <!-- Dashboard -->
    <menuitem
        id="menu_ecopulse_dashboard"
        name="Dashboard"
        parent="menu_ecopulse_root"
        action="action_ecopulse_dashboard"
        sequence="1"
    />

    <!-- Environmental Main Menu -->
    <menuitem
        id="menu_ecopulse_environmental"
        name="Environmental"
        parent="menu_ecopulse_root"
        sequence="10"
    />

    <!-- Carbon Transactions -->
    <menuitem
        id="menu_ecopulse_transactions"
        name="Carbon Transactions"
        parent="menu_ecopulse_environmental"
        action="action_ecopulse_carbon_transaction"
        sequence="10"
    />

    <!-- Environmental Goals -->
    <menuitem
        id="menu_ecopulse_goals"
        name="Environmental Goals"
        parent="menu_ecopulse_environmental"
        action="action_ecopulse_environmental_goal"
        sequence="20"
    />

    <!-- Configuration Main Menu -->
    <menuitem
        id="menu_ecopulse_configuration"
        name="Configuration"
        parent="menu_ecopulse_root"
        sequence="90"
    />

    <!-- Departments -->
    <menuitem
        id="menu_ecopulse_departments"
        name="Departments"
        parent="menu_ecopulse_configuration"
        action="action_ecopulse_department"
        sequence="10"
    />

    <!-- Emission Factors -->
    <menuitem
        id="menu_ecopulse_emission_factors"
        name="Emission Factors"
        parent="menu_ecopulse_configuration"
        action="action_ecopulse_emission_factor"
        sequence="20"
    />

</odoo>