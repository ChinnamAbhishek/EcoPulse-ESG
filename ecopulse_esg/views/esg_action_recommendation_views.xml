<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- =====================================================
         ESG ACTION RECOMMENDATION LIST VIEW
         ===================================================== -->

    <record
        id="view_ecopulse_esg_action_recommendation_list"
        model="ir.ui.view">

        <field name="name">
            ecopulse.esg.action.recommendation.list
        </field>

        <field name="model">ecopulse.esg.action.recommendation</field>

        <field name="arch" type="xml">

            <list
                string="ESG Action Recommendations"
                decoration-danger="priority == 'critical'"
                decoration-warning="priority == 'high'"
                decoration-success="status == 'completed'"
                decoration-muted="status == 'rejected'">

                <field name="name"/>

                <field name="title"/>

                <field name="recommendation_source"/>

                <field name="department_id"/>

                <field name="responsible_user_id"/>

                <field name="priority"/>

                <field name="target_date"/>

                <field name="baseline_emission"/>

                <field name="expected_reduction_percent"/>

                <field name="expected_reduction_emission"/>

                <field name="impact_score"/>

                <field name="status"/>

            </list>

        </field>

    </record>


    <!-- =====================================================
         ESG ACTION RECOMMENDATION FORM VIEW
         ===================================================== -->

    <record
        id="view_ecopulse_esg_action_recommendation_form"
        model="ir.ui.view">

        <field name="name">
            ecopulse.esg.action.recommendation.form
        </field>

        <field name="model">ecopulse.esg.action.recommendation</field>

        <field name="arch" type="xml">

            <form
                string="ESG Action Recommendation"
                class="o_ecopulse_esg_action_form">

                <!-- WORKFLOW HEADER -->

                <header>

                    <button
                        name="action_approve"
                        string="Approve"
                        type="object"
                        class="btn-primary"
                        invisible="status != 'proposed'"
                        groups="ecopulse_esg.group_ecopulse_manager"/>

                    <button
                        name="action_start"
                        string="Start Action"
                        type="object"
                        class="btn-primary"
                        invisible="status not in ('approved', 'proposed')"
                        groups="ecopulse_esg.group_ecopulse_manager"/>

                    <button
                        name="action_complete"
                        string="Mark Completed"
                        type="object"
                        class="btn-primary"
                        invisible="status != 'in_progress'"
                        groups="ecopulse_esg.group_ecopulse_manager"/>

                    <button
                        name="action_reject"
                        string="Reject"
                        type="object"
                        invisible="status in ('completed', 'rejected')"
                        groups="ecopulse_esg.group_ecopulse_manager"/>

                    <button
                        name="action_reset_to_proposed"
                        string="Reset to Proposed"
                        type="object"
                        invisible="status not in ('completed', 'rejected')"
                        groups="ecopulse_esg.group_ecopulse_manager"/>

                    <button
                        name="action_open_source_record"
                        string="Open Source Record"
                        type="object"
                        class="btn-secondary"
                        icon="fa-external-link"/>

                    <field
                        name="status"
                        widget="statusbar"
                        statusbar_visible="proposed,approved,in_progress,completed,rejected"/>

                </header>


                <sheet>

                    <!-- =============================================
                         MODERN HERO SECTION
                         ============================================= -->

                    <div class="o_ecopulse_action_hero">

                        <div class="o_ecopulse_action_hero_content">

                            <div class="o_ecopulse_action_reference">

                                <i class="fa fa-leaf me-2"/>

                                <field
                                    name="name"
                                    readonly="1"
                                    nolabel="1"/>

                            </div>

                            <div class="oe_title o_ecopulse_action_title">

                                <h1>

                                    <field
                                        name="title"
                                        nolabel="1"
                                        placeholder="Enter smart ESG action title..."/>

                                </h1>

                            </div>

                            <div class="o_ecopulse_action_subtitle">

                                AI-assisted sustainability recommendation
                                for measurable emission reduction and
                                environmental improvement.

                            </div>

                        </div>

                    </div>


                    <!-- =============================================
                         INTERACTIVE KPI CARDS
                         ============================================= -->

                    <div class="o_ecopulse_action_kpis">

                        <!-- IMPACT SCORE CARD -->

                        <div
                            class="o_ecopulse_kpi_card
                                   o_ecopulse_kpi_primary">

                            <div class="o_ecopulse_kpi_icon">

                                <i class="fa fa-line-chart"/>

                            </div>

                            <div class="o_ecopulse_kpi_label">

                                Impact Score

                            </div>

                            <div class="o_ecopulse_kpi_value">

                                <field
                                    name="impact_score"
                                    readonly="1"
                                    nolabel="1"/>

                            </div>

                            <div class="o_ecopulse_kpi_unit">

                                Sustainability impact out of 100

                            </div>

                        </div>


                        <!-- BASELINE EMISSION CARD -->

                        <div class="o_ecopulse_kpi_card">

                            <div class="o_ecopulse_kpi_icon">

                                <i class="fa fa-cloud"/>

                            </div>

                            <div class="o_ecopulse_kpi_label">

                                Baseline Emission

                            </div>

                            <div class="o_ecopulse_kpi_value">

                                <field
                                    name="baseline_emission"
                                    nolabel="1"/>

                            </div>

                            <div class="o_ecopulse_kpi_unit">

                                kg CO2e before action

                            </div>

                        </div>


                        <!-- EXPECTED REDUCTION CARD -->

                        <div
                            class="o_ecopulse_kpi_card
                                   o_ecopulse_kpi_warning">

                            <div class="o_ecopulse_kpi_icon">

                                <i class="fa fa-arrow-down"/>

                            </div>

                            <div class="o_ecopulse_kpi_label">

                                Expected Reduction

                            </div>

                            <div class="o_ecopulse_kpi_value">

                                <field
                                    name="expected_reduction_emission"
                                    readonly="1"
                                    nolabel="1"/>

                            </div>

                            <div class="o_ecopulse_kpi_unit">

                                kg CO2e estimated reduction

                            </div>

                        </div>


                        <!-- PROJECTED EMISSION CARD -->

                        <div
                            class="o_ecopulse_kpi_card
                                   o_ecopulse_kpi_info">

                            <div class="o_ecopulse_kpi_icon">

                                <i class="fa fa-bullseye"/>

                            </div>

                            <div class="o_ecopulse_kpi_label">

                                Projected Emission

                            </div>

                            <div class="o_ecopulse_kpi_value">

                                <field
                                    name="projected_emission"
                                    readonly="1"
                                    nolabel="1"/>

                            </div>

                            <div class="o_ecopulse_kpi_unit">

                                kg CO2e after implementation

                            </div>

                        </div>

                    </div>


                    <!-- =============================================
                         ACTION OVERVIEW PANEL
                         ============================================= -->

                    <div class="o_ecopulse_action_panel">

                        <div class="o_ecopulse_action_panel_title">

                            <i class="fa fa-lightbulb-o"/>

                            <span>Action Overview</span>

                        </div>

                        <group>

                            <group>

                                <field name="recommendation_source"/>

                                <field
                                    name="priority"
                                    decoration-danger="priority == 'critical'"
                                    decoration-warning="priority == 'high'"
                                    decoration-success="priority == 'low'"/>

                                <field name="department_id"/>

                                <field name="responsible_user_id"/>

                            </group>

                            <group>

                                <field name="generated_date"/>

                                <field name="target_date"/>

                                <field
                                    name="completed_date"
                                    readonly="1"/>

                                <field name="active"/>

                            </group>

                        </group>

                    </div>


                    <!-- =============================================
                         ENVIRONMENTAL IMPACT PANEL
                         ============================================= -->

                    <div class="o_ecopulse_action_panel">

                        <div class="o_ecopulse_action_panel_title">

                            <i class="fa fa-area-chart"/>

                            <span>
                                Environmental Impact Projection
                            </span>

                        </div>

                        <group>

                            <group>

                                <field name="baseline_emission"/>

                                <field name="expected_reduction_percent"/>

                                <field
                                    name="expected_reduction_emission"
                                    readonly="1"/>

                            </group>

                            <group>

                                <field
                                    name="projected_emission"
                                    readonly="1"/>

                                <field name="actual_reduction_emission"/>

                                <field
                                    name="impact_score"
                                    readonly="1"
                                    widget="progressbar"/>

                            </group>

                        </group>

                    </div>


                    <!-- =============================================
                         LINKED ESG RECORDS PANEL
                         ============================================= -->

                    <div class="o_ecopulse_action_panel">

                        <div class="o_ecopulse_action_panel_title">

                            <i class="fa fa-link"/>

                            <span>Linked ESG Records</span>

                        </div>

                        <group>

                            <group>

                                <field name="carbon_transaction_id"/>

                            </group>

                            <group>

                                <field name="carbon_budget_id"/>

                            </group>

                        </group>

                    </div>


                    <!-- =============================================
                         ACTION DETAILS NOTEBOOK
                         ============================================= -->

                    <notebook>

                        <!-- RECOMMENDED ACTION TAB -->

                        <page string="Recommended Action">

                            <div class="o_ecopulse_action_panel">

                                <div
                                    class="o_ecopulse_action_panel_title">

                                    <i
                                        class="fa
                                               fa-exclamation-triangle"/>

                                    <span>Problem Detected</span>

                                </div>

                                <field
                                    name="problem_detected"
                                    nolabel="1"
                                    placeholder="Describe the ESG issue detected by EcoPulse..."/>

                            </div>


                            <div class="o_ecopulse_action_panel">

                                <div
                                    class="o_ecopulse_action_panel_title">

                                    <i class="fa fa-magic"/>

                                    <span>
                                        Recommended Corrective Action
                                    </span>

                                </div>

                                <field
                                    name="description"
                                    nolabel="1"
                                    placeholder="Describe the recommended corrective action..."/>

                            </div>


                            <div class="o_ecopulse_action_panel">

                                <div
                                    class="o_ecopulse_action_panel_title">

                                    <i class="fa fa-trophy"/>

                                    <span>Expected Benefit</span>

                                </div>

                                <field
                                    name="expected_benefit"
                                    nolabel="1"
                                    placeholder="Describe the environmental and operational benefits..."/>

                            </div>

                        </page>


                        <!-- IMPLEMENTATION PLAN TAB -->

                        <page string="Implementation Plan">

                            <div class="o_ecopulse_action_panel">

                                <div
                                    class="o_ecopulse_action_panel_title">

                                    <i class="fa fa-tasks"/>

                                    <span>Implementation Steps</span>

                                </div>

                                <field
                                    name="implementation_steps"
                                    nolabel="1"
                                    placeholder="1. Assign owner&#10;2. Implement action&#10;3. Monitor progress&#10;4. Verify results"/>

                            </div>


                            <div class="o_ecopulse_action_panel">

                                <div
                                    class="o_ecopulse_action_panel_title">

                                    <i class="fa fa-check-circle"/>

                                    <span>Verification Method</span>

                                </div>

                                <field
                                    name="verification_method"
                                    nolabel="1"
                                    placeholder="Explain how the emission reduction will be measured and verified..."/>

                            </div>

                        </page>


                        <!-- MANAGEMENT REVIEW TAB -->

                        <page string="Management Review">

                            <div class="o_ecopulse_action_panel">

                                <div
                                    class="o_ecopulse_action_panel_title">

                                    <i class="fa fa-comments"/>

                                    <span>
                                        Management Review Notes
                                    </span>

                                </div>

                                <field
                                    name="management_note"
                                    nolabel="1"
                                    placeholder="Add approval notes, review comments or implementation decisions..."/>

                            </div>

                        </page>

                    </notebook>

                </sheet>


                <!-- CHATTER -->

                <chatter/>

            </form>

        </field>

    </record>


    <!-- =====================================================
         ESG ACTION RECOMMENDATION SEARCH VIEW
         ===================================================== -->

    <record
        id="view_ecopulse_esg_action_recommendation_search"
        model="ir.ui.view">

        <field name="name">
            ecopulse.esg.action.recommendation.search
        </field>

        <field name="model">ecopulse.esg.action.recommendation</field>

        <field name="arch" type="xml">

            <search string="Search ESG Recommendations">

                <field name="name"/>

                <field name="title"/>

                <field name="department_id"/>

                <field name="responsible_user_id"/>

                <field name="recommendation_source"/>

                <field name="priority"/>

                <field name="status"/>

                <field name="target_date"/>


                <filter
                    name="filter_critical"
                    string="Critical Priority"
                    domain="[('priority', '=', 'critical')]"/>

                <filter
                    name="filter_high"
                    string="High Priority"
                    domain="[('priority', '=', 'high')]"/>

                <filter
                    name="filter_open"
                    string="Open Actions"
                    domain="[
                        (
                            'status',
                            'in',
                            [
                                'proposed',
                                'approved',
                                'in_progress'
                            ]
                        )
                    ]"/>

                <filter
                    name="filter_overdue"
                    string="Overdue"
                    domain="[
                        (
                            'target_date',
                            '&lt;',
                            context_today()
                        ),
                        (
                            'status',
                            'not in',
                            [
                                'completed',
                                'rejected'
                            ]
                        )
                    ]"/>

                <filter
                    name="filter_completed"
                    string="Completed"
                    domain="[('status', '=', 'completed')]"/>

                <filter
                    name="filter_budget_source"
                    string="Budget Recommendations"
                    domain="[
                        (
                            'recommendation_source',
                            '=',
                            'budget'
                        )
                    ]"/>

                <filter
                    name="filter_anomaly_source"
                    string="Anomaly Recommendations"
                    domain="[
                        (
                            'recommendation_source',
                            '=',
                            'anomaly'
                        )
                    ]"/>

                <filter
                    name="filter_greenwashing_source"
                    string="Greenwashing Recommendations"
                    domain="[
                        (
                            'recommendation_source',
                            '=',
                            'greenwashing'
                        )
                    ]"/>

                <separator/>

                <filter
                    name="group_by_priority"
                    string="Group by Priority"
                    context="{'group_by': 'priority'}"/>

                <filter
                    name="group_by_status"
                    string="Group by Status"
                    context="{'group_by': 'status'}"/>

                <filter
                    name="group_by_department"
                    string="Group by Department"
                    context="{'group_by': 'department_id'}"/>

                <filter
                    name="group_by_source"
                    string="Group by Source"
                    context="{
                        'group_by': 'recommendation_source'
                    }"/>

                <filter
                    name="group_by_target_month"
                    string="Group by Target Month"
                    context="{
                        'group_by': 'target_date:month'
                    }"/>

            </search>

        </field>

    </record>


    <!-- =====================================================
         ESG ACTION RECOMMENDATION KANBAN VIEW
         ===================================================== -->

    <record
        id="view_ecopulse_esg_action_recommendation_kanban"
        model="ir.ui.view">

        <field name="name">
            ecopulse.esg.action.recommendation.kanban
        </field>

        <field name="model">ecopulse.esg.action.recommendation</field>

        <field name="arch" type="xml">

            <kanban
                default_group_by="status"
                class="o_kanban_small_column
                       o_ecopulse_esg_action_kanban">

                <field name="name"/>

                <field name="title"/>

                <field name="priority"/>

                <field name="department_id"/>

                <field name="responsible_user_id"/>

                <field name="target_date"/>

                <field name="impact_score"/>

                <field name="expected_reduction_emission"/>

                <field name="status"/>

                <templates>

                    <t t-name="card">

                        <div
                            class="oe_kanban_global_click
                                   o_ecopulse_kanban_card">

                            <div
                                class="o_ecopulse_kanban_header">

                                <div
                                    class="d-flex
                                           justify-content-between
                                           align-items-start
                                           gap-2">

                                    <strong>

                                        <field name="title"/>

                                    </strong>


                                    <span
                                        t-if="
                                            record.priority.raw_value
                                            == 'critical'
                                        "
                                        class="badge text-bg-danger">

                                        Critical

                                    </span>


                                    <span
                                        t-elif="
                                            record.priority.raw_value
                                            == 'high'
                                        "
                                        class="badge text-bg-warning">

                                        High

                                    </span>


                                    <span
                                        t-elif="
                                            record.priority.raw_value
                                            == 'medium'
                                        "
                                        class="badge text-bg-info">

                                        Medium

                                    </span>


                                    <span
                                        t-else=""
                                        class="badge text-bg-success">

                                        Low

                                    </span>

                                </div>

                                <div class="text-muted mt-1">

                                    <i class="fa fa-leaf me-1"/>

                                    <field name="name"/>

                                </div>

                            </div>


                            <div class="o_ecopulse_kanban_body">

                                <div class="o_ecopulse_kanban_metric">

                                    <span>Department</span>

                                    <strong>

                                        <field name="department_id"/>

                                    </strong>

                                </div>


                                <div class="o_ecopulse_kanban_metric">

                                    <span>Responsible Owner</span>

                                    <strong>

                                        <field
                                            name="responsible_user_id"/>

                                    </strong>

                                </div>


                                <div class="o_ecopulse_kanban_metric">

                                    <span>Target Date</span>

                                    <strong>

                                        <field name="target_date"/>

                                    </strong>

                                </div>


                                <div class="o_ecopulse_kanban_metric">

                                    <span>Expected Reduction</span>

                                    <strong>

                                        <field
                                            name="expected_reduction_emission"/>

                                        kg CO2e

                                    </strong>

                                </div>


                                <div class="mt-3">

                                    <field
                                        name="impact_score"
                                        widget="progressbar"/>

                                </div>

                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>

    </record>


    <!-- =====================================================
         ESG ACTION RECOMMENDATION GRAPH VIEW
         ===================================================== -->

    <record
        id="view_ecopulse_esg_action_recommendation_graph"
        model="ir.ui.view">

        <field name="name">
            ecopulse.esg.action.recommendation.graph
        </field>

        <field name="model">ecopulse.esg.action.recommendation</field>

        <field name="arch" type="xml">

            <graph
                string="Expected ESG Impact"
                type="bar">

                <field name="department_id"/>

                <field
                    name="expected_reduction_emission"
                    type="measure"/>

                <field
                    name="actual_reduction_emission"
                    type="measure"/>

            </graph>

        </field>

    </record>


    <!-- =====================================================
         ESG ACTION RECOMMENDATION WINDOW ACTION
         ===================================================== -->

    <record
        id="action_ecopulse_esg_action_recommendation"
        model="ir.actions.act_window">

        <field name="name">
            Smart ESG Actions
        </field>

        <field name="res_model">ecopulse.esg.action.recommendation</field>

        <field name="view_mode">kanban,list,form,graph</field>

        <field
            name="search_view_id"
            ref="view_ecopulse_esg_action_recommendation_search"/>

        <field
            name="context"
            eval="{
                'search_default_filter_open': 1
            }"/>

        <field name="help" type="html">

            <p class="o_view_nocontent_smiling_face">

                Create your first smart ESG action

            </p>

            <p>

                Convert carbon risks, budget overruns and emission
                anomalies into measurable sustainability actions.

            </p>

        </field>

    </record>

</odoo>
