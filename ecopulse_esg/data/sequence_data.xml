<?xml version="1.0" encoding="UTF-8"?>

<odoo noupdate="1">

    <!-- Carbon Transaction Sequence -->
    <record
        id="seq_ecopulse_carbon_transaction"
        model="ir.sequence">

        <field name="name">Carbon Transaction</field>
        <field name="code">ecopulse.carbon.transaction</field>
        <field name="prefix">CARB/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>

    </record>


    <!-- Department Carbon Budget Sequence -->
    <record
        id="seq_ecopulse_carbon_budget"
        model="ir.sequence">

        <field name="name">Department Carbon Budget</field>
        <field name="code">ecopulse.carbon.budget</field>
        <field name="prefix">CB/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>

    </record>


    <!-- ESG Action Recommendation Sequence -->
    <record
        id="seq_ecopulse_esg_action_recommendation"
        model="ir.sequence">

        <field name="name">ESG Action Recommendation</field>
        <field name="code">ecopulse.esg.action.recommendation</field>
        <field name="prefix">ESG-ACT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>

    </record>

</odoo>